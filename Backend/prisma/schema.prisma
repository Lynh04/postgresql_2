generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  courses   Course[] // Quan hệ Many-to-Many
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  code        String   @unique
  users       User[]   // Quan hệ Many-to-Many
}